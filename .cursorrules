{
  "background": {
    "description": "ClassMaster是一个面向学校的智能班级管理系统，使用Flask框架构建，提供学生信息管理、成绩记录、评语生成、德育评价等功能。本系统针对中国教育环境设计，特别关注班主任工作流程优化和数据分析需求。",
    "target_users": ["班主任", "学校管理员"],
    "development_stage": "生产环境",
    "key_features": ["学生管理", "成绩分析", "评语生成", "德育评价", "数据导出"]
  },
  "coding_standards": {
    "python": {
      "style": "PEP 8",
      "function_naming": "snake_case",
      "class_naming": "PascalCase",
      "constants": "UPPER_CASE",
      "indentation": "4空格",
      "docstrings": "必须，使用中文",
      "max_line_length": 120
    },
    "javascript": {
      "style": "Prettier配置",
      "function_naming": "camelCase",
      "component_naming": "PascalCase",
      "variable_naming": "camelCase",
      "prefer": ["ES6语法", "箭头函数", "async/await"],
      "avoid": ["var关键字", "回调地狱"]
    },
    "html_css": {
      "class_naming": "功能-组件-状态",
      "id_naming": "camelCase",
      "css_selectors": "具体组件命名，避免过度通用选择器"
    }
  },
  "preferred_libraries": {
    "python": {
      "web_framework": "Flask",
      "data_processing": ["pandas", "numpy"],
      "excel_handling": "openpyxl",
      "pdf_generation": "reportlab",
      "testing": "pytest"
    },
    "frontend": {
      "framework": "Bootstrap 5",
      "dom_manipulation": "jQuery",
      "datetime": "moment.js",
      "charts": "Chart.js",
      "data_tables": "DataTables",
      "form_validation": "Bootstrap Validation"
    },
    "apis": {
      "ai_completion": "DeepSeek API"
    }
  },
  "file_structure": {
    "root_modules": {
      "server.py": "应用程序入口点和主要路由",
      "users.py": "用户认证和权限管理",
      "students.py": "学生信息管理",
      "grades.py": "成绩管理",
      "comments.py": "评语管理",
      "deyu.py": "德育评价管理",
      "classes.py": "班级管理",
      "grade_analysis.py": "成绩分析功能"
    },
    "directories": {
      "models/": "数据模型定义",
      "templates/": "HTML模板文件",
      "static/": "静态资源",
      "js/": "JavaScript文件",
      "css/": "样式表文件",
      "utils/": "辅助工具",
      "exports/": "导出文件存储",
      "uploads/": "上传文件存储",
      "logs/": "日志文件存储"
    },
    "database": "students.db"
  },
  "performance_optimization": {
    "database": {
      "use_indexes": true,
      "query_optimization": "避免循环中执行查询",
      "connection_management": "使用连接池或上下文管理器"
    },
    "frontend": {
      "resource_loading": "按需加载JavaScript文件",
      "image_optimization": "压缩并缓存图片",
      "dom_operations": "减少DOM操作，使用事件委托",
      "responsive_design": "使用Bootstrap媒体查询适配不同设备"
    },
    "caching": {
      "static_resources": "添加适当的缓存控制头",
      "api_responses": "缓存较少变化的数据查询结果"
    }
  },
  "testing_requirements": {
    "unit_testing": {
      "framework": "pytest",
      "coverage": "核心模块需达到80%覆盖率",
      "naming": "test_[被测试的函数名].py"
    },
    "integration_testing": {
      "routes": "测试所有API端点",
      "authentication": "测试各种权限场景",
      "database": "测试数据库交互"
    },
    "ui_testing": {
      "responsive": "验证在不同屏幕尺寸下的布局",
      "accessibility": "确保界面元素可访问"
    },
    "测试规范": {
      "完成后说明": [
        "【<项目名称>】的测试已创建完成，请查看README.md已更新。测试文件已保存在对应目录中。"
      ],
      "测试说明格式": [
        "<测试用例1>：[测试目的描述]",
        "<测试用例2>：[测试目的概述]",
        "..."
      ],
      "输出内容规范": "如果输出内容暂时长度过长，提示用户：\"由于篇幅内容较长，输出暂停，请输入*//#续**，我将继续输出测试内容。\""
    }
  },
  "documentation": {
    "code": {
      "require_docstrings": true,
      "docstring_style": "中文，描述功能、参数、返回值",
      "inline_comments": "解释复杂逻辑",
      "preferred_language": "zh-CN"
    },
    "api": {
      "format": "统一返回JSON格式，包含status和message字段",
      "error_codes": "定义明确的错误代码系统",
      "version": "在路由中包含API版本"
    },
    "user_guides": {
      "admin_guide": "管理员操作手册",
      "teacher_guide": "教师使用指南"
    }
  },
  "error_handling": {
    "python": {
      "exceptions": "使用自定义异常类",
      "logging": "错误需记录到日志文件",
      "client_feedback": "适当转换为用户友好消息"
    },
    "javascript": {
      "promise_errors": "使用.catch()或try/catch处理Promise错误",
      "ajax_errors": "显示用户友好的错误消息",
      "global_handler": "实现全局错误处理函数"
    },
    "api_responses": {
      "status_codes": "正确使用HTTP状态码",
      "error_format": {
        "status": "error",
        "message": "用户友好消息",
        "code": "错误代码",
        "details": "详细错误信息(仅开发环境)"
      }
    }
  },
  "language": {
    "strict-default": "zh-CN",
    "accept": ["zh-CN", "en"],
    "never": ["jp", "fr", "de"]
  },
  "style": {
    "code-comment-style": "chinese",
    "docstring-style": "chinese",
    "variable-naming": "chinese-pinyin-allowed"
  },
  "code": {
    "max-line-length": 120,
    "formatters": {
      "py": "black",
      "js": "prettier",
      "html": "prettier",
      "css": "prettier"
    },
    "linters": {
      "py": "flake8",
      "js": "eslint"
    }
  },
  "project": {
    "name": "ClassMaster",
    "version": "2.2",
    "description": "智能班级管理系统",
    "type": "web-app",
    "structure": {
      "backend": "flask",
      "frontend": "bootstrap",
      "database": "sqlite"
    }
  },
  "team": {
    "code-review-required": true,
    "code-owners": {
      "server.py": ["admin"],
      "users.py": ["admin"],
      "models/*": ["admin"],
      "js/*": ["frontend-dev"],
      "css/*": ["frontend-dev"]
    }
  },
  "security": {
    "allow-secrets-in-code": false,
    "prefer-environment-variables": true,
    "sensitive-data-patterns": [
      "DEEPSEEK_API_KEY",
      "SECRET_KEY",
      "password",
      "密码"
    ],
    "authentication": {
      "password_policy": "至少8位，包含大小写字母和数字",
      "session_management": "使用Flask-Login",
      "csrf_protection": "必须启用"
    },
    "data_validation": {
      "input_sanitization": "防止XSS和注入攻击",
      "file_uploads": "验证文件类型和大小"
    }
  },
  "cursor-ai": {
    "code-generation": {
      "style": "match-existing",
      "prefer-libraries": ["flask", "pandas", "openpyxl", "reportlab"],
      "database-schema-aware": true
    },
    "code-completion": {
      "context-size": "large",
      "variable-naming-convention": "match-existing"
    },
    "prompt-templates": {
      "add-feature": "添加一个新功能到{component}组件，功能描述：{description}",
      "fix-bug": "修复{component}中的问题：{description}，注意保持代码风格一致",
      "optimize": "优化{component}的性能，特别关注{focus_area}"
    }
  },
  "file-templates": {
    "python-module": [
      "# -*- coding: utf-8 -*-",
      "\"\"\"",
      "{description}",
      "\"\"\"",
      "",
      "import os",
      "import logging",
      "",
      "logger = logging.getLogger(__name__)",
      "",
      "# 代码实现...",
      ""
    ],
    "flask-blueprint": [
      "# -*- coding: utf-8 -*-",
      "\"\"\"",
      "{name} - {description}",
      "\"\"\"",
      "",
      "from flask import Blueprint, request, jsonify",
      "",
      "{name}_bp = Blueprint('{name}', __name__)",
      "",
      "@{name}_bp.route('/{route}', methods=['GET'])",
      "def index():",
      "    return jsonify({'status': 'success', 'message': '{name}模块运行正常'})",
      ""
    ],
    "js-module": [
      "/**",
      " * {name} - {description}",
      " */",
      "",
      "$(document).ready(function() {",
      "    // 初始化代码",
      "});",
      ""
    ]
  },
  "dependency-management": {
    "python": {
      "dependency-file": "requirements.txt",
      "virtual-env": true
    },
    "javascript": {
      "dependency-file": "package.json",
      "package-manager": "npm"
    }
  },
  "db-schema": {
    "tables": [
      "students",
      "users",
      "classes",
      "grades",
      "comments",
      "exams",
      "deyu_records"
    ],
    "primary-entities": ["students", "users", "classes"]
  },
  "功能": {
    "检查项目目录": "执行<不带项目名称的执行><显示开发>功能",
    "检查": "执行<代码检查>功能",
    "测试": "执行<测试开发>功能、方指定测试（针对元素）",
    "问题": "执行<解决问题>功能",
    "健康检查": "通过查阅README.md，.cursorrules和开发好的现代代码执行健康检查任务，页面完整性开发"
  },
  "项目状态检测": [
    "当用户在项目运行中遇到一个含错误的自动生成README.md时提示",
    "我正在分析项目当前状态，请稍等...",
    "根据README.md中的开发状态查察表和已有文件，确定项目进度",
    "如果存在规划但未开发的模块：建议用户是否开始开发",
    "如果需要测试已开发模块：建议用户先完成已开发内容，建议用户是否需要执行测试",
    "如果所有规划已开发完毕：建议用户是否需要运行测试确认功能",
    "通过README.md文件检查到已完成7个核心页面列表的开发，还有<未完成项目列表>未开发。"
  ],
  "交互风格": [
    "优先读取用户反馈内容",
    "全面阅读相关代码，理解++代码结构++工作原理",
    "简要用户的问题分析成问题点简述，提出解决问题的思路",
    "回答时以最精简的方式不会影响表达小的范围",
    "始终使用中文"
  ],
  "指令集": {
    "开发": "不带项目名称执行<执行开发>功能",
    "检查": "执行<代码检查>功能",
    "测试": "执行<测试开发>功能、可指定测试元素",
    "问题": "执行<解决问题>功能"
  },
  "初始化": {
    "检查项目目录": [
      "如果README.md不存在：创建基础项目，执行以下初始化：",
      "如果项目为iOS或移动应用，执行<iOS应用开发>或其他对应平台的初始化"
    ]
  },
  "功能模块": {
    "学生管理": {
      "描述": "学生基本信息的增删改查与管理",
      "关键文件": ["students.py", "js/students.js"],
      "数据表": "students",
      "必要功能": ["学生列表", "学生详情", "学生添加", "学生编辑", "学生删除", "学生搜索", "学生数据导入导出"]
    },
    "成绩管理": {
      "描述": "学生成绩的录入、查询与统计分析",
      "关键文件": ["grades.py", "js/grades.js", "grade_analysis.py"],
      "数据表": ["grades", "exams"],
      "必要功能": ["成绩录入", "成绩查询", "成绩统计", "成绩分析图表", "成绩导入导出"]
    },
    "评语管理": {
      "描述": "学生评语的生成、编辑与管理",
      "关键文件": ["comments.py", "js/comments.js"],
      "数据表": "comments",
      "必要功能": ["评语模板管理", "AI评语生成", "评语编辑", "评语导出"]
    },
    "德育评价": {
      "描述": "学生德育素质的评价与记录",
      "关键文件": ["deyu.py", "js/deyu.js"],
      "数据表": "deyu_records",
      "必要功能": ["德育评价录入", "德育评价查询", "德育评价统计", "德育评价导出"]
    },
    "班级管理": {
      "描述": "班级信息的管理与统计",
      "关键文件": ["classes.py", "js/classes.js"],
      "数据表": "classes",
      "必要功能": ["班级列表", "班级详情", "班级添加", "班级编辑", "班级删除"]
    },
    "用户管理": {
      "描述": "用户账号的管理与权限控制",
      "关键文件": ["users.py", "js/admin.js"],
      "数据表": "users",
      "必要功能": ["用户列表", "用户添加", "用户编辑", "用户删除", "权限管理", "密码重置"]
    }
  },
  "数据流向": {
    "学生信息流": ["学生基本信息录入", "班级关联", "成绩录入", "评语生成", "德育评价", "数据导出"],
    "教师工作流": ["登录系统", "查看班级", "管理学生", "记录成绩", "撰写评语", "评定德育表现", "生成报告"],
    "管理员工作流": ["系统配置", "用户管理", "数据备份", "整体数据分析"]
  },
  "开发指南": {
    "新功能开发流程": [
      "1. 确认需求并在README.md中添加功能描述",
      "2. 设计数据模型和API接口",
      "3. 实现后端路由和功能",
      "4. 开发前端界面和交互",
      "5. 编写单元测试和集成测试",
      "6. 文档更新"
    ],
    "代码提交规范": {
      "commit_message_format": "<类型>: <简要描述>",
      "commit_types": {
        "feat": "新功能",
        "fix": "修复Bug",
        "docs": "文档更新",
        "style": "代码风格调整，不影响功能",
        "refactor": "代码重构，不添加新功能或修复Bug",
        "perf": "性能优化",
        "test": "添加测试",
        "chore": "构建过程或辅助工具变动"
      }
    },
    "代码审查要点": [
      "功能完整性：是否实现了所有需求",
      "代码质量：是否符合编码规范",
      "性能考虑：是否有性能瓶颈",
      "安全性：是否存在安全隐患",
      "可维护性：代码结构是否清晰",
      "测试覆盖：测试是否充分"
    ]
  },
  "AI辅助开发": {
    "适用场景": [
      "评语模板生成",
      "代码补全",
      "Bug修复建议",
      "性能优化建议",
      "文档生成"
    ],
    "提示词模板": {
      "评语生成": "根据以下学生的{成绩表现}、{德育表现}和{特长}，生成一段{字数}字的评语，风格{积极/客观/严格}",
      "代码优化": "分析以下代码中可能存在的性能问题，并提供优化建议：{代码块}",
      "功能实现": "实现一个{功能描述}，使用{技术栈}，需要考虑{特殊需求}"
    }
  },
  "部署指南": {
    "生产环境": {
      "系统要求": "Windows 10+/Linux",
      "Python版本": "3.7+",
      "Web服务器": "Gunicorn + Nginx",
      "数据库": "SQLite(小规模)/MySQL(大规模)",
      "缓存": "Redis(可选)",
      "备份策略": "每日自动备份数据库"
    },
    "开发环境": {
      "虚拟环境": "venv",
      "依赖管理": "pip + requirements.txt",
      "本地调试": "Flask内置服务器"
    },
    "环境变量": [
      "FLASK_ENV=development/production",
      "SECRET_KEY=<应用密钥>",
      "DEEPSEEK_API_KEY=<AI API密钥>"
    ]
  }
} 