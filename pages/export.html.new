    <script src="../js/libs/bootstrap.bundle.min.js"></script>
    <script src="../js/data.js"></script>
    <script src="../js/export.js"></script>
    <script src="../js/template-upload.js"></script>
    <script>
        // 动态加载文档库文件
        function loadDocxLibraries(callback) {
            // 动态加载PizZip
            const pizzipScript = document.createElement('script');
            pizzipScript.src = '../libs/pizzip.min.js';
            
            // 动态加载Docxtemplater
            const docxtemplaterScript = document.createElement('script');
            docxtemplaterScript.src = '../libs/docxtemplater.js';
            
            // 动态加载jszip
            const jszipScript = document.createElement('script');
            jszipScript.src = '../libs/jszip.min.js';
            
            // 将脚本添加到head中
            document.head.appendChild(pizzipScript);
            document.head.appendChild(docxtemplaterScript);
            document.head.appendChild(jszipScript);
            
            // 等待脚本加载完成
            Promise.all([
                new Promise(resolve => pizzipScript.onload = resolve),
                new Promise(resolve => docxtemplaterScript.onload = resolve),
                new Promise(resolve => jszipScript.onload = resolve)
            ]).then(() => {
                // 调用回调函数
                callback();
            });
        }
        
        // 初始化页面
        document.addEventListener('DOMContentLoaded', async function() {
            // 动态加载文档库文件
            try {
                await loadDocxLibraries(() => {
                    console.log('Docx库加载成功');
                });
            } catch (error) {
                console.error('加载Docx库失败:', error);
                showNotification('加载Docx库失败，可能会影响功能', 'error');
            }
            
            // 初始化导出设置
            initExportSettings();
            
            // 初始化学生列表
            initStudentList();
            
            // 初始化模板上传
            initTemplateUpload();
            
            // 点击导出按钮的监听器
            document.getElementById('exportBtn').addEventListener('click', exportReports);
            
            // 点击上传模板按钮的监听器
            document.getElementById('uploadTemplateBtn').addEventListener('click', function() {
                document.getElementById('templateUpload').click();
            });
            
            // 页面加载完成后尝试获取模板并获取模板列表
            try {
                // 检查默认模板是否存在
                const response = await fetch('/api/templates');
                if (response.ok) {
                    const data = await response.json();
                    if (data.status === 'ok' && data.templates && data.templates.length > 0) {
                        // 渲染模板卡片
                        const templateContainer = document.getElementById('templateContainer');
                        if (templateContainer) {
                            // 清空模板容器
                            templateContainer.innerHTML = '';
                            
                            // 添加模板卡片
                            data.templates.forEach(template => {
                                const card = document.createElement('div');
                                card.className = 'col-md-4 mb-3';
                                card.innerHTML = `
                                    <div class="card template-card" data-template-id="${template.id}">
                                        <div class="card-body">
                                            <h5 class="card-title">${template.name}</h5>
                                            <p class="card-text">
                                                <small class="text-muted">${template.type === 'system' ? '系统模板' : '自定义模板'}</small>
                                            </p>
                                        </div>
                                    </div>
                                `;
                                templateContainer.appendChild(card);
                                
                                // 添加点击监听器
                                const templateCard = card.querySelector('.template-card');
                                templateCard.addEventListener('click', function() {
                                    selectTemplate(this);
                                });
                            });
                            
                            // 选择第一个模板
                            const firstTemplate = templateContainer.querySelector('.template-card');
                            if (firstTemplate) {
                                selectTemplate(firstTemplate);
                            }
                        }
                    } else {
                        // 没有找到模板，提示上传
                        showNotification('没有找到需要的模板，请上传模板', 'warning');
                    }
                }
            } catch (error) {
                console.error('获取模板列表失败:', error);
            }
        });
        
        // 显示通知提示
        function showNotification(message, type = 'success') {
            const toast = document.getElementById('notificationToast');
            const toastBody = toast.querySelector('.toast-body');
            toastBody.textContent = message;
            
            // 清除通知提示
            toast.classList.remove('bg-success', 'bg-danger', 'bg-info', 'text-white');
            const icon = toast.querySelector('.toast-header i');
            icon.classList.remove('bx-info-circle', 'bx-check-circle', 'bx-error-circle');
            
            switch(type) {
                case 'error':
                    toast.classList.add('bg-danger', 'text-white');
                    icon.classList.add('bx-error-circle');
                    break;
                case 'info':
                    toast.classList.add('bg-info', 'text-white');
                    icon.classList.add('bx-info-circle');
                    break;
                default:
                    toast.classList.add('bg-success', 'text-white');
                    icon.classList.add('bx-check-circle');
            }
            
            // 显示通知提示
            const bsToast = new bootstrap.Toast(toast);
            bsToast.show();
        }
        
        // 点击预览按钮的监听器
        document.getElementById('exportFromPreviewBtn').addEventListener('click', function() {
            // 关闭预览模态框
            const previewModal = bootstrap.Modal.getInstance(document.getElementById('previewModal'));
            previewModal.hide();
            
            // 生成报告
            document.getElementById('exportBtn').click();
        });
    </script>
    <!-- 模板使用说明 -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="card-title mb-0">模板使用说明</h5>
        </div>
        <div class="card-body">
            <p>在Word模板中，可以使用以下格式替换为应学生的信息：</p>
            <p><strong>占位符格式：</strong> 使用双大括号{{}}，例如{{学生姓名}}</p>
            <div class="row">
                <div class="col-md-4">
                    <div class="card mb-3">
                        <div class="card-header">
                            <h6 class="mb-0">学生信息</h6>
                        </div>
                        <div class="card-body">
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>学生</span>
                                    <code>{{学生姓名}}</code>
                                </li>
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>班级</span>
                                    <code>{{班级}}</code>
                                </li>
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>性别</span>
                                    <code>{{性别}}</code>
                                </li>
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>年龄</span>
                                    <code>{{年龄}}</code>
                                </li>
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>出生日期</span>
                                    <code>{{出生日期}}</code>
                                </li>
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>电话</span>
                                    <code>{{电话}}</code>
                                </li>
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>地址</span>
                                    <code>{{地址}}</code>
                                </li>
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>邮箱</span>
                                    <code>{{邮箱}}</code>
                                </li>
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>身份证号</span>
                                    <code>{{身份证号}}</code>
                                </li>
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>学号</span>
                                    <code>{{学号}}</code>
                                </li>
